# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# Random secret — used by the iOS app to authenticate API requests
API_KEY=change_me_to_a_long_random_string

# Your Bambu printer's local IP address
PRINTER_IP=192.168.1.x

# Bambu printer serial number (shown in Bambu Studio → Device)
PRINTER_SERIAL=

# Bambu printer LAN access code (shown in printer screen → Network)
PRINTER_ACCESS_CODE=

# Public URL of this server (used for image mirroring)
BASE_URL=http://your-nas-hostname:3456
